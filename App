<!DOCTYPE html>
<html>
<head>
  <title>Elite Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0d0d0d;
      color: gold;
    }

    .header {
      padding: 15px;
      text-align: center;
      font-size: 20px;
      font-weight: bold;
      background: black;
      border-bottom: 1px solid gold;
    }

    .container {
      padding: 20px;
    }

    .card {
      background: #1a1a1a;
      padding: 15px;
      margin-bottom: 15px;
      border-radius: 10px;
    }

    button {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
      background: gold;
      color: black;
      border: none;
      border-radius: 8px;
      font-weight: bold;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-top: 10px;
      border-radius: 8px;
      border: none;
    }

    .nav {
      position: fixed;
      bottom: 0;
      width: 100%;
      display: flex;
      background: black;
      border-top: 1px solid gold;
    }

    .nav button {
      flex: 1;
      background: black;
      color: gold;
      border: none;
      padding: 15px;
    }
  </style>
</head>

<body>

<div class="header">Elite Hub</div>

<div class="container" id="content">

  <h2>Welcome 👋</h2>
  <p>Earn, find jobs, and access deals instantly.</p>

  <input id="phone" placeholder="Enter your number">

  <div class="card">
    <h3>📄 CV Writing</h3>
    <p>Professional CV for KSh 200</p>
    <button onclick="order('CV Writing')">Get CV</button>
  </div>

  <div class="card">
    <h3>💼 Job Alerts</h3>
    <p>Daily job opportunities</p>
    <button onclick="order('Job Alerts')">Get Jobs</button>
  </div>

  <div class="card">
    <h3>💡 Hustle Ideas</h3>
    <p>Start earning today</p>
    <button onclick="order('Hustles')">Get Ideas</button>
  </div>

</div>

<div class="nav">
  <button onclick="home()">Home</button>
  <button onclick="services()">Services</button>
  <button onclick="profile()">Profile</button>
</div>

<script>
function order(service) {
  let phone = document.getElementById("phone").value || "No number";

  let message = `Hello, I want ${service}. My number is ${phone}`;

  let url = `https://wa.me/254792091769?text=${encodeURIComponent(message)}`;

  window.open(url, "_blank");
}

function home() {
  location.reload();
}

function services() {
  document.getElementById("content").innerHTML = `
    <h2>Services</h2>

    <div class="card">
      <h3>🛍 Fashion Deals</h3>
      <button onclick="order('Fashion Deals')">Order Now</button>
    </div>

    <div class="card">
      <h3>📱 Online Hustles</h3>
      <button onclick="order('Online Hustles')">Start Now</button>
    </div>
  `;
}

function profile() {
  document.getElementById("content").innerHTML = `
    <h2>Your Profile</h2>
    <p>Save your number for faster orders</p>
  `;
}
</script>

</body>
</html>
